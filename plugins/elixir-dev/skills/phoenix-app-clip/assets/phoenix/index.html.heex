<%!-- Shell for the LiveView. Place at lib/<app>_web/live/__name___live/index.html.heex
     Replace <App>/__Name__/__name__. The live_component receives the initial data
     and token, which it encodes onto the placeholder node for the hook to read. --%>
<h1>{@page_title}</h1>

<.live_component
  id="__name__"
  module={<App>Web.__Name__Live.LiveComponent.__Name__}
  initial={@initial}
  token={@token}
/>
